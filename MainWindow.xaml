<Window x:Class="TileViewer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:TileViewer.Views"
        Title="TileViewer" Width="1400" Height="800"
        MinWidth="600" MinHeight="400"
        Style="{StaticResource BaseWindowStyle}"
        WindowStartupLocation="CenterScreen">
    <Window.InputBindings>
        <KeyBinding Modifiers="Control" Key="N" Command="{Binding AddPanelCommand, RelativeSource={RelativeSource AncestorType=Window}}" />
    </Window.InputBindings>

    <DockPanel LastChildFill="True">
        <!-- Toolbar -->
        <Border DockPanel.Dock="Top" Background="{StaticResource CrustBrush}"
                BorderBrush="{StaticResource Surface0Brush}" BorderThickness="0,0,0,1"
                Padding="6,4">
            <DockPanel LastChildFill="True">
                <Button Content="+ Panel" Padding="12,3" Margin="2,0"
                        Click="AddPanel_Click" DockPanel.Dock="Left" />
                <CheckBox x:Name="SyncCheck" Content="Sync Panels" IsChecked="True"
                          Margin="12,0,0,0" VerticalAlignment="Center" DockPanel.Dock="Left"
                          Foreground="{StaticResource TextBrush}" />
                <TextBlock x:Name="StatusText" Text="0 tilesets"
                           Foreground="{StaticResource Overlay0Brush}"
                           VerticalAlignment="Center" HorizontalAlignment="Right"
                           Margin="10,0" />
            </DockPanel>
        </Border>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition x:Name="SidebarCol" Width="320" MinWidth="200" />
                <ColumnDefinition Width="4" />
                <ColumnDefinition Width="*" MinWidth="400" />
            </Grid.ColumnDefinitions>

            <views:SiteBrowserView x:Name="Browser" Grid.Column="0" />

            <GridSplitter Grid.Column="1" HorizontalAlignment="Stretch"
                          Background="{StaticResource Surface0Brush}" />

            <Grid x:Name="PanelHost" Grid.Column="2" Background="{StaticResource BaseBrush}" />
        </Grid>
    </DockPanel>
</Window>
