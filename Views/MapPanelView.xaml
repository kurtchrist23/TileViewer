<UserControl x:Class="TileViewer.Views.MapPanelView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource MantleBrush}"
             Focusable="True">
    <DockPanel LastChildFill="True">
        <!-- Header -->
        <Border DockPanel.Dock="Top" Background="{StaticResource MantleBrush}"
                BorderBrush="{StaticResource Surface0Brush}" BorderThickness="0,0,0,1"
                Padding="4,2">
            <DockPanel LastChildFill="True">
                <TextBlock x:Name="DriveLabel" DockPanel.Dock="Left"
                           Foreground="{StaticResource RedBrush}"
                           FontWeight="Bold" VerticalAlignment="Center" Margin="4,0,6,0" />
                <Button x:Name="OpenBtn" DockPanel.Dock="Left"
                        Content="&#x1F4C2;" FontSize="12"
                        Padding="6,1" Margin="2,0" Click="OpenBtn_Click"
                        ToolTip="Open tileset folder" />
                <Button x:Name="DeepBtn" DockPanel.Dock="Left"
                        Content="&#x1F50D;" FontSize="12"
                        Padding="6,1" Margin="0,0,2,0" Click="DeepBtn_Click"
                        ToolTip="Search site folder for tileset" />
                <ComboBox x:Name="TilesetCombo" DockPanel.Dock="Left"
                          Width="240" Margin="4,0"
                          SelectionChanged="TilesetCombo_SelectionChanged" />
                <Button x:Name="CloseBtn" DockPanel.Dock="Right"
                        Content="&#x2715;" FontSize="12"
                        Padding="8,1" Margin="2,0"
                        Foreground="{StaticResource RedBrush}"
                        Click="CloseBtn_Click"
                        ToolTip="Close panel" />
                <TextBlock x:Name="InfoLabel" Text="(empty)"
                           Foreground="{StaticResource Overlay0Brush}"
                           VerticalAlignment="Center" Margin="6,0" />
            </DockPanel>
        </Border>

        <!-- Map canvas -->
        <Grid x:Name="CanvasHost" Background="{StaticResource CrustBrush}" ClipToBounds="True">
            <Canvas x:Name="TileCanvas" Background="Transparent"
                    MouseLeftButtonDown="Canvas_MouseLeftButtonDown"
                    MouseMove="Canvas_MouseMove"
                    MouseLeftButtonUp="Canvas_MouseLeftButtonUp"
                    MouseLeave="Canvas_MouseLeftButtonUp"
                    MouseWheel="Canvas_MouseWheel"
                    SizeChanged="Canvas_SizeChanged" />
            <StackPanel x:Name="OverlayPanel" IsHitTestVisible="False"
                        HorizontalAlignment="Center" VerticalAlignment="Top"
                        Margin="0,8,0,0">
                <TextBlock x:Name="DriveOverlay" Foreground="{StaticResource RedBrush}"
                           FontWeight="Bold" FontSize="12" HorizontalAlignment="Center" />
                <TextBlock x:Name="NameOverlay" Foreground="{StaticResource TextBrush}"
                           FontWeight="Bold" FontSize="12" HorizontalAlignment="Center" />
                <TextBlock x:Name="CoordOverlay" Foreground="{StaticResource Overlay0Brush}"
                           FontFamily="Consolas" FontSize="10" HorizontalAlignment="Center" />
            </StackPanel>
            <TextBlock x:Name="ZoomOverlay" IsHitTestVisible="False"
                       HorizontalAlignment="Left" VerticalAlignment="Bottom"
                       Margin="10,0,0,6" Foreground="{StaticResource Overlay0Brush}"
                       FontFamily="Consolas" FontSize="10" />
            <TextBlock x:Name="EmptyText" IsHitTestVisible="False"
                       HorizontalAlignment="Center" VerticalAlignment="Center"
                       Foreground="{StaticResource Overlay0Brush}" FontSize="13"
                       Text="Open or select a tileset" />
        </Grid>
    </DockPanel>
</UserControl>
