<Window x:Class="TileViewer.Views.AboutWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Style="{StaticResource BaseWindowStyle}"
        Title="About TileViewer"
        Width="480" SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False">
    <StackPanel Margin="24">
        <TextBlock Text="TileViewer"
                   FontSize="24" FontWeight="Bold"
                   Foreground="{StaticResource BlueBrush}" />
        <TextBlock x:Name="VersionText"
                   FontSize="13"
                   Foreground="{StaticResource Subtext0Brush}"
                   Margin="0,2,0,16" />

        <TextBlock TextWrapping="Wrap" Foreground="{StaticResource TextBrush}" Margin="0,0,0,16">
            Side-by-side viewer for TMS (Tile Map Service) tile sets. Each panel is
            independent — load any tileset, pan and zoom freely, and optionally sync
            the view across panels for direct visual comparison of overlapping sites.
        </TextBlock>

        <Border Background="{StaticResource Surface0Brush}" CornerRadius="6" Padding="14" Margin="0,0,0,12">
            <StackPanel>
                <TextBlock Text="Author"
                           FontWeight="Bold" FontSize="12"
                           Foreground="{StaticResource BlueBrush}"
                           Margin="0,0,0,4" />
                <TextBlock Text="Kurt Christ" Foreground="{StaticResource TextBrush}" Margin="0,0,0,8" />

                <TextBlock Text="Organization"
                           FontWeight="Bold" FontSize="12"
                           Foreground="{StaticResource BlueBrush}"
                           Margin="0,0,0,4" />
                <TextBlock Text="Sensor Evaluation &amp; Digital Prototyping Division"
                           Foreground="{StaticResource TextBrush}" />
                <TextBlock Text="C5ISR Research and Technology Integration Directorate (RTI)"
                           Foreground="{StaticResource Subtext0Brush}" FontSize="12" />
            </StackPanel>
        </Border>

        <Border Background="{StaticResource Surface0Brush}" CornerRadius="6" Padding="14" Margin="0,0,0,16">
            <StackPanel>
                <TextBlock Text="Third-Party Libraries"
                           FontWeight="Bold" FontSize="12"
                           Foreground="{StaticResource BlueBrush}"
                           Margin="0,0,0,6" />
                <TextBlock Foreground="{StaticResource TextBrush}" TextWrapping="Wrap">
                    <Run FontWeight="SemiBold">CommunityToolkit.Mvvm</Run>
                    <Run Foreground="{DynamicResource Subtext0Brush}"> — MVVM helpers (MIT)</Run>
                </TextBlock>
                <TextBlock Foreground="{StaticResource TextBrush}" TextWrapping="Wrap" Margin="0,4,0,0">
                    <Run FontWeight="SemiBold">.NET 8 / WPF</Run>
                    <Run Foreground="{DynamicResource Subtext0Brush}"> — Microsoft (MIT)</Run>
                </TextBlock>
            </StackPanel>
        </Border>

        <Button Content="OK" Style="{StaticResource PrimaryButton}"
                MinWidth="100" HorizontalAlignment="Right"
                IsDefault="True" IsCancel="True"
                Click="Ok_Click" />
    </StackPanel>
</Window>
